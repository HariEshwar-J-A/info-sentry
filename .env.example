# ─────────────────────────────────────────────────────────────────────────────
#  Info-Sentry — environment variables
#  Copy to .env and fill in your values.
#  Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
POSTGRES_USER=infosentry
POSTGRES_PASSWORD=change-me-use-a-strong-password
DATABASE_URL="postgresql://openclaw_role:openclaw_password@127.0.0.1:5432/infosentry"

# ── ChromaDB (Docker) ─────────────────────────────────────────────────────────
CHROMA_URL="http://127.0.0.1:8000"

# ── OpenRouter (LLM) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-..."

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="..."
TELEGRAM_ADMIN_ID="123456789"
TELEGRAM_SUPERGROUP_ID="-100..."

# ── Budget (USD/month) ────────────────────────────────────────────────────────
MONTHLY_BUDGET_USD="7.30"
DAILY_BUDGET_USD="0.24"

# ── Web authentication (Google OAuth) ────────────────────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: https://sentry.yourdomain.com/api/auth/callback
# Stored in web/.env.local (not here — these are web-only vars)
# GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-..."
# ALLOWED_EMAILS="you@gmail.com"            # comma-separated allowlist
# APP_URL="https://sentry.yourdomain.com"   # public URL of the app
# WEB_AUTH_SECRET="run: openssl rand -hex 32"

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# GITHUB_TOKEN="ghp_..."

# ── Scout v3 / ScrapeGraphAI sidecar ───────────────────────────────────────────
# Infra: make db-up   OR   docker compose up -d   → sidecar on http://127.0.0.1:8811
# Web/UI pipelines spawned from web/: mirror SCRAPEGRAPH_URL + models in web/.env.local if needed.

SCRAPEGRAPH_URL="http://127.0.0.1:8811"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# LLMs — cheap defaults (OpenRouter); Node uses QUERY_EXPAND*, Docker sidecar uses SGAI_MODEL from compose/.env
QUERY_EXPAND_MODEL="google/gemini-2.0-flash-001"
SGAI_MODEL="google/gemini-2.0-flash-001"
# OPENROUTER_MAX_RETRIES_429="5"
# OPENROUTER_FALLBACK_MAX_RETRIES_429="3"
# OPENROUTER_RATE_LIMIT_FALLBACK_MODELS="openai/gpt-4o-mini,deepseek/deepseek-v3.2"
# ANALYST_PROCESS_TIMEOUT_MS="420000"
# PREDICTION_PROCESS_TIMEOUT_MS="420000"
# QUERY_EXPAND_MAX="5"
# QUERY_EXPAND_CACHE_DIR="./data/cache/query-expand"

# Cost / behaviour guards
SGAI_MAX_CALLS_PER_RUN="30"
SGAI_MIN_CONTENT_LEN="400"
SGAI_SEARCH_FALLBACK="true"
# SGAI_TIMEOUT_MS="120000"
# SGAI_RETRIES="2"
# SGAI_SEARCH_TIMEOUT_MS="180000"
# SGAI_FOLLOW_TIMEOUT_MS="60000"

# Sidecar Chromium / verbosity (passed through docker-compose.yml → scrapegraph service)
# SGAI_HEADLESS="true"
# SGAI_VERBOSE="false"
# SGAI_TEMPERATURE="0.2"

# Scout discovery volume / freshness (scripts/scout-run.ts)
# MAX_PER_TOPIC="12"
# MAX_ARTICLE_AGE_DAYS="3"
# HISTORICAL_MODE="false"

# Telegram bot /run — scout subprocess timeout (ms); Scout v3 benefits from ≥900000
SCOUT_SCRIPT_TIMEOUT_MS="900000"

# Telemetry — scrapegraph Docker sets SCRAPEGRAPHAI_TELEMETRY_ENABLED=false by default
# SCRAPEGRAPHAI_TELEMETRY_ENABLED=false

# ── Misc ──────────────────────────────────────────────────────────────────────
ARTICLES_DIR="./data/articles"
NODE_ENV="development"
