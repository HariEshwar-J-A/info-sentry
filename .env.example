# Database
DATABASE_URL="postgresql://user:password@localhost:5432/infosentry"

# OpenRouter
OPENROUTER_API_KEY="sk-or-..."

# Telegram
TELEGRAM_BOT_TOKEN="..."
TELEGRAM_ADMIN_ID="123456789"
TELEGRAM_SUPERGROUP_ID="-100..."

# ChromaDB
CHROMA_URL="http://localhost:8000"

# Budget (USD)
MONTHLY_BUDGET_USD="7.30"
DAILY_BUDGET_USD="0.24"

# Scraped articles storage
ARTICLES_DIR="./data/articles"

# Web authentication (single user)
# Set all three to enable the login screen when accessed publicly.
# Leave unset for local development (no login required).
# WEB_AUTH_USERNAME="your-username"
# WEB_AUTH_PASSWORD="your-strong-passphrase-here"
# WEB_AUTH_SECRET="generate with: openssl rand -hex 32"

# GitHub PAT (optional — raises rate limit from 10 to 30 req/min)
# GITHUB_TOKEN="ghp_..."

# Environment
NODE_ENV="development"
