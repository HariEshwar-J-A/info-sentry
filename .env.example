# ─────────────────────────────────────────────────────────────────────────────
#  Info-Sentry — environment variables
#  Copy to .env and fill in your values.
#  Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
# User + password for the Docker container (docker-compose.yml reads these)
POSTGRES_USER=infosentry
POSTGRES_PASSWORD=change-me-use-a-strong-password

# Prisma connection string — must match POSTGRES_USER / POSTGRES_PASSWORD above
DATABASE_URL="postgresql://infosentry:change-me-use-a-strong-password@127.0.0.1:5432/infosentry"

# ── ChromaDB (Docker) ─────────────────────────────────────────────────────────
CHROMA_URL="http://127.0.0.1:8000"

# ── OpenRouter (LLM) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-..."

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="..."
TELEGRAM_ADMIN_ID="123456789"           # your Telegram user ID
TELEGRAM_SUPERGROUP_ID="-100..."        # supergroup chat ID (negative number)

# ── Budget (USD/month) ────────────────────────────────────────────────────────
MONTHLY_BUDGET_USD="7.30"
DAILY_BUDGET_USD="0.24"

# ── Web authentication ────────────────────────────────────────────────────────
# Set all three to enable the login screen (required when accessed publicly).
# Leave commented out for local development — no login required.
# WEB_AUTH_USERNAME="your-username"
# WEB_AUTH_PASSWORD="your-strong-passphrase"
# WEB_AUTH_SECRET="run: openssl rand -hex 32"

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# Personal Access Token — raises rate limit from 10 to 30 req/min
# GITHUB_TOKEN="ghp_..."

# ── Misc ──────────────────────────────────────────────────────────────────────
ARTICLES_DIR="./data/articles"
NODE_ENV="development"
