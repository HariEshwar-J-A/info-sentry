generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ───────────────────────────────────────────────────
model User {
  id         String   @id @default(cuid())
  telegramId String   @unique
  username   String?
  isAdmin    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  interests    Interest[]
  chatMessages ChatMessage[]

  @@index([telegramId])
}

// ─── Interest ───────────────────────────────────────────────
model Interest {
  id          String   @id @default(cuid())
  userId      String
  topic       String
  description String?
  score       Float    @default(1.0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources InterestSource[]

  @@unique([userId, topic])
  @@index([isActive])
}

// ─── Source ─────────────────────────────────────────────────
model Source {
  id          String      @id @default(cuid())
  name        String
  url         String      @unique
  type        SourceType  @default(WEB)
  trustScore  Float       @default(0.5)
  isActive    Boolean     @default(true)
  crawlMethod CrawlMethod @default(CHEERIO)
  rssUrl      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  interests InterestSource[]
  articles  Article[]

  @@index([isActive])
  @@index([trustScore])
}

enum SourceType {
  WEB
  RSS
  API
}

enum CrawlMethod {
  CHEERIO
  PLAYWRIGHT
}

// ─── InterestSource (Junction) ──────────────────────────────
model InterestSource {
  id         String   @id @default(cuid())
  interestId String
  sourceId   String
  createdAt  DateTime @default(now())

  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)
  source   Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([interestId, sourceId])
}

// ─── Article ────────────────────────────────────────────────
model Article {
  id          String        @id @default(cuid())
  sourceId    String
  url         String        @unique
  title       String
  rawFilePath String?
  status      ArticleStatus @default(SCRAPED)
  scrapedAt   DateTime      @default(now())
  analyzedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  source      Source       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  summary     Summary?
  predictions Prediction[]

  @@index([scrapedAt])
  @@index([status])
  @@index([createdAt])
  @@index([sourceId, scrapedAt])
}

enum ArticleStatus {
  SCRAPED
  ANALYZING
  SUMMARIZED
  POSTED
  FAILED
}

// ─── Summary ────────────────────────────────────────────────
model Summary {
  id              String   @id @default(cuid())
  articleId       String   @unique
  content         String
  keyTopics       String[]
  sentimentScore  Float?
  relevanceScore  Float?
  chromaId        String?
  telegramMsgId   Int?
  telegramTopicId Int?
  createdAt       DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

// ─── Prediction ─────────────────────────────────────────────
model Prediction {
  id              String           @id @default(cuid())
  articleId       String
  content         String
  confidence      Float
  timeHorizon     String?
  status          PredictionStatus @default(PENDING)
  telegramMsgId   Int?
  telegramTopicId Int?
  createdAt       DateTime         @default(now())
  resolvedAt      DateTime?
  outcome         String?

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

enum PredictionStatus {
  PENDING
  CORRECT
  INCORRECT
  PARTIALLY_CORRECT
  EXPIRED
}

// ─── MediaContent (Video/Audio transcripts) ─────────────────
model MediaContent {
  id           String    @id @default(cuid())
  articleId    String
  type         MediaType
  url          String
  title        String?
  duration     String?
  transcript   String?
  extractedAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([articleId, type])
  @@index([createdAt])
}

enum MediaType {
  VIDEO
  AUDIO
  PODCAST
}

// ─── Validation Queue (Human-in-the-loop) ───────────────────
model ValidationQueue {
  id           String           @id @default(cuid())
  predictionId String
  articleId    String
  summary      String
  predictions  Json
  confidence   Float
  status       ValidationStatus @default(PENDING)
  submittedAt  DateTime         @default(now())
  resolvedAt   DateTime?
  postedAt     DateTime?
  resolvedBy   String?

  @@index([status])
  @@index([submittedAt])
  @@index([confidence])
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

// ─── Prediction Outcome Tracking ────────────────────────────
model PredictionOutcome {
  id              String    @id @default(cuid())
  predictionId    String
  expectedOutcome String
  actualOutcome   String?
  accuracyScore   Float?
  verifiedAt      DateTime?
  verifiedBy      String?
  notes           String?
  createdAt       DateTime  @default(now())

  @@index([predictionId])
  @@index([verifiedAt])
}

// ─── ChatMessage ────────────────────────────────────────────
model ChatMessage {
  id        String      @id @default(cuid())
  userId    String
  role      MessageRole
  content   String
  agentName String?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ─── AgentConfig ────────────────────────────────────────────
model AgentConfig {
  id           String    @id @default(cuid())
  agentName    String    @unique
  isActive     Boolean   @default(true)
  cronSchedule String?
  settings     Json      @default("{}")
  lastRunAt    DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── CostLog ────────────────────────────────────────────────
model CostLog {
  id               String   @id @default(cuid())
  agentName        String
  modelId          String
  promptTokens     Int
  completionTokens Int
  totalCostUsd     Float
  openrouterGenId  String?
  createdAt        DateTime @default(now())

  @@index([agentName, createdAt])
  @@index([createdAt])
}

// ─── Budget Status ──────────────────────────────────────────
model BudgetStatus {
  id             String   @id @default(cuid())
  month          Int
  year           Int
  budgetUsd      Float
  spentUsd       Float    @default(0)
  dailyBudgetUsd Float
  currentTier    Int      @default(2)
  lastCheckAt    DateTime @default(now())
  alertsSent     String[] @default([])

  @@unique([year, month])
}

// ─── ForumTopic ─────────────────────────────────────────────
model ForumTopic {
  id              String   @id @default(cuid())
  name            String   @unique
  telegramTopicId Int      @unique
  createdAt       DateTime @default(now())
}
