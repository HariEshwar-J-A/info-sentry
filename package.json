{
  "name": "info-sentry",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate --schema prisma/schema.prisma && prisma generate --schema prisma/scout-schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:roles": "psql -f prisma/roles.sql",
    "postinstall": "npm run db:generate",
    "scout": "tsx scripts/scout-run.ts",
    "pipeline": "tsx scripts/pipeline-run.ts",
    "health": "tsx scripts/health-check.ts",
    "budget": "tsx scripts/budget-check.ts",
    "db": "tsx scripts/db-query.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "chromadb": "^3.4.0",
    "crawlee": "^3.12.0",
    "dotenv": "^16.5.0",
    "openai": "^4.80.0",
    "playwright": "^1.50.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
