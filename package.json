{
  "name": "info-sentry",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "./scripts/manage.sh dev",
    "start": "./scripts/manage.sh start",
    "stop": "./scripts/manage.sh stop",
    "restart": "./scripts/manage.sh restart",
    "status": "./scripts/manage.sh status",
    "build": "tsc",
    "postinstall": "npm run db:generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:roles": "psql -f prisma/roles.sql",
    "pipeline": "tsx scripts/pipeline-run.ts",
    "scout": "tsx scripts/scout-run.ts",
    "scout:rss": "tsx scripts/scout-rss.ts",
    "scout:sitemap": "tsx scripts/scout-sitemap.ts",
    "scout:pdf": "tsx scripts/scout-pdf.ts",
    "github:scan": "tsx scripts/github-scout.ts && tsx scripts/github-analyst.ts",
    "health": "tsx scripts/health-check.ts",
    "budget": "tsx scripts/budget-check.ts",
    "db": "tsx scripts/db-query.ts",
    "bot": "tsx scripts/telegram-bot.ts",
    "bot:dev": "tsx watch scripts/telegram-bot.ts"
  },
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "@prisma/client": "^6.7.0",
    "archiver": "^7.0.0",
    "cheerio": "^1.0.0-rc.12",
    "chromadb": "^3.4.0",
    "crawlee": "^3.12.0",
    "dotenv": "^16.5.0",
    "fast-xml-parser": "^4.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-cron": "^4.2.1",
    "openai": "^4.80.0",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.50.0",
    "rss-parser": "^3.13.0",
    "sitemap": "^7.1.1",
    "xml2js": "^0.6.2",
    "yt-dlp-exec": "^1.0.2",
    "zod": "^3.24.0"
  },
  "overrides": {
    "tr46": "^5.0.0",
    "whatwg-url": "^14.0.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/xml2js": "^0.4.14",
    "concurrently": "^9.2.1",
    "prisma": "^6.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
