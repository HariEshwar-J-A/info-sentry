{
  "$schema": "https://openclaw.dev/schema/v1/cron.json",
  "jobs": [
    {
      "name": "daily-digest",
      "schedule": "0 9 * * *",
      "description": "Send daily summary at 9 AM (once per day, budget-friendly)",
      "agent": "manager",
      "exec": "npx tsx scripts/daily-digest.ts"
    },
    {
      "name": "scout-hourly",
      "schedule": "*/30 * * * *",
      "description": "Scout run every 30 minutes for fresh articles",
      "agent": "scout",
      "exec": "npx tsx scripts/scout-run.ts",
      "condition": "budgetCheck"
    },
    {
      "name": "pipeline-hourly",
      "schedule": "10,40 * * * *",
      "description": "Process scraped articles at :10 and :40 (after each scout run)",
      "agent": "analyst",
      "exec": "npx tsx scripts/pipeline-run.ts",
      "condition": "budgetCheck"
    },
    {
      "name": "system-log",
      "schedule": "*/30 * * * *",
      "description": "Post health snapshot to System-Log supergroup topic every 30 minutes",
      "agent": "manager",
      "exec": "npx tsx scripts/system-log-post.ts"
    },
    {
      "name": "budget-check",
      "schedule": "0 */6 * * *",
      "description": "Budget status report every 6 hours",
      "agent": "manager",
      "exec": "npx tsx scripts/budget-check.ts"
    },
    {
      "name": "auto-approve-high-confidence",
      "schedule": "0 10 * * *",
      "description": "Auto-approve high-confidence predictions",
      "agent": "manager",
      "exec": "npx tsx scripts/validation-queue.ts --action=auto-approve-high-confidence"
    }
  ]
}
