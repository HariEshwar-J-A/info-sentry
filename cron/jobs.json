{
  "$schema": "https://openclaw.dev/schema/v1/cron.json",
  "jobs": [
    {
      "name": "scout-scrape",
      "schedule": "0 */2 * * *",
      "description": "Scrape sources for new articles every 2 hours at :00",
      "agent": "scout",
      "exec": "npx tsx scripts/scout-run.ts"
    },
    {
      "name": "pipeline-process",
      "schedule": "15 */2 * * *",
      "description": "Analyze + predict + post scraped articles every 2 hours at :15",
      "agent": "analyst",
      "exec": "npx tsx scripts/pipeline-run.ts"
    },
    {
      "name": "health-check",
      "schedule": "*/15 * * * *",
      "description": "System health check every 15 minutes",
      "agent": "manager",
      "exec": "npx tsx scripts/health-check.ts"
    },
    {
      "name": "budget-check",
      "schedule": "0 */6 * * *",
      "description": "Budget status report every 6 hours",
      "agent": "manager",
      "exec": "npx tsx scripts/budget-check.ts"
    }
  ]
}
