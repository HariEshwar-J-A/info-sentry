{
  "$schema": "https://openclaw.dev/schema/v1/openclaw.json",
  "version": "1.0",
  "name": "info-sentry",
  "description": "Personal news intelligence system with 5 AI agents",

  "gateway": {
    "host": "127.0.0.1",
    "port": 18789
  },

  "providers": {
    "openrouter": {
      "type": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "default_headers": {
        "HTTP-Referer": "https://github.com/info-sentry",
        "X-Title": "Info-Sentry"
      }
    }
  },

  "models": {
    "deepseek-v3": {
      "provider": "openrouter",
      "model_id": "deepseek/deepseek-v3.2"
    },
    "gemini-flash": {
      "provider": "openrouter",
      "model_id": "google/gemini-3.1-flash-lite"
    }
  },

  "bindings": {
    "telegram": {
      "bot_token_env": "TELEGRAM_BOT_TOKEN"
    }
  },

  "agents": {
    "manager": {
      "soul": "agents/manager/SOUL.md",
      "model": "gemini-flash",
      "binding": {
        "type": "telegram",
        "chat_id_env": "TELEGRAM_ADMIN_ID",
        "scope": "private"
      },
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": true,
          "allowed_commands": [
            "npx tsx scripts/health-check.ts",
            "npx tsx scripts/budget-check.ts",
            "npx tsx scripts/db-query.ts *"
          ]
        }
      }
    },

    "feedback": {
      "soul": "agents/feedback/SOUL.md",
      "model": "gemini-flash",
      "binding": {
        "type": "telegram",
        "chat_id_env": "TELEGRAM_SUPERGROUP_ID",
        "scope": "group"
      },
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": true,
          "allowed_commands": [
            "npx tsx scripts/db-query.ts *",
            "npx tsx scripts/telegram-callback.ts *"
          ]
        }
      }
    },

    "scout": {
      "soul": "agents/scout/SOUL.md",
      "model": "gemini-flash",
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": true,
          "allowed_commands": [
            "npx tsx scripts/scout-run.ts"
          ]
        }
      }
    },

    "analyst": {
      "soul": "agents/analyst/SOUL.md",
      "model": "deepseek-v3",
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": true,
          "allowed_commands": [
            "npx tsx scripts/pipeline-run.ts"
          ]
        }
      }
    },

    "prediction": {
      "soul": "agents/prediction/SOUL.md",
      "model": "deepseek-v3",
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": true,
          "allowed_commands": [
            "npx tsx scripts/prediction-process.ts *"
          ]
        }
      }
    }
  },

  "cron": "cron/jobs.json"
}
