{
  "$schema": "https://openclaw.dev/schema/v1/openclaw.json",
  "version": "1.0",
  "name": "info-sentry",
  "description": "Personal news intelligence system — slave agent under Vision (master at :18789)",

  "gateway": {
    "host": "127.0.0.1",
    "port": 18790
  },

  "providers": {
    "openrouter": {
      "type": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "default_headers": {
        "HTTP-Referer": "https://github.com/HariEshwar-J-A/info-sentry",
        "X-Title": "Info-Sentry"
      }
    }
  },

  "models": {
    "kimi-k2.6": {
      "provider": "openrouter",
      "model_id": "moonshotai/kimi-k2.6"
    },
    "deepseek-v3": {
      "provider": "openrouter",
      "model_id": "deepseek/deepseek-v3.2"
    },
    "gemini-flash": {
      "provider": "openrouter",
      "model_id": "google/gemini-3.1-flash-lite"
    }
  },

  "bindings": {
    "telegram": {
      "bot_token_env": "TELEGRAM_BOT_TOKEN"
    }
  },

  "agents": {
    "coder": {
      "soul": "agents/coder.md",
      "model": "kimi-k2.6",
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": false,
          "allowed_commands": [
            "npx tsc --noEmit",
            "npx tsx scripts/*.ts *",
            "npm run *",
            "git status",
            "git diff *",
            "git log --oneline *",
            "git add *",
            "git commit *",
            "git push *"
          ]
        }
      }
    },

    "manager": {
      "soul": "agents/manager.md",
      "model": "deepseek-v3",
      "binding": {
        "type": "telegram",
        "chat_id_env": "TELEGRAM_ADMIN_ID",
        "scope": "private"
      },
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": true,
          "allowed_commands": [
            "npx tsx scripts/health-check.ts",
            "npx tsx scripts/budget-check.ts",
            "npx tsx scripts/db-query.ts *",
            "npx tsx scripts/system-log-post.ts"
          ]
        }
      }
    },

    "feedback": {
      "soul": "agents/feedback.md",
      "model": "deepseek-v3",
      "binding": {
        "type": "telegram",
        "chat_id_env": "TELEGRAM_SUPERGROUP_ID",
        "scope": "group"
      },
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": true,
          "allowed_commands": [
            "npx tsx scripts/db-query.ts *",
            "npx tsx scripts/telegram-callback.ts *"
          ]
        }
      }
    },

    "scout": {
      "soul": "agents/scout.md",
      "model": "gemini-flash",
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": false,
          "allowed_commands": [
            "npx tsx scripts/scout-run.ts"
          ]
        }
      }
    },

    "analyst": {
      "soul": "agents/analyst.md",
      "model": "deepseek-v3",
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": false,
          "allowed_commands": [
            "npx tsx scripts/pipeline-run.ts"
          ]
        }
      }
    },

    "prediction": {
      "soul": "agents/prediction.md",
      "model": "kimi-k2.6",
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": false,
          "allowed_commands": [
            "npx tsx scripts/prediction-process.ts *",
            "npx tsx scripts/prediction-verifier.ts",
            "npx tsx scripts/prediction-verifier.ts --dryRun"
          ]
        }
      }
    },

    "verifier": {
      "soul": "agents/prediction.md",
      "model": "kimi-k2.6",
      "tools": {
        "exec": {
          "enabled": true,
          "exec_ask": false,
          "allowed_commands": [
            "npx tsx scripts/prediction-verifier.ts",
            "npx tsx scripts/prediction-verifier.ts --dryRun"
          ]
        }
      }
    }
  },

  "cron": "cron/jobs.json"
}
