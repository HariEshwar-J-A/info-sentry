# ── Required ──────────────────────────────────────────────────────────────────

# 32+ character random string — used to sign session cookies and OAuth state
# Generate: openssl rand -hex 32
WEB_AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# Google OAuth app credentials (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OpenRouter API key for LLM calls
OPENROUTER_API_KEY=sk-or-...

# Database connection
DATABASE_URL=postgresql://openclaw_role:password@localhost:5432/infosentry

# ── Access Control ─────────────────────────────────────────────────────────────

# Comma-separated Gmail addresses allowed to sign in.
# When empty/unset: any Google account can sign in (Google Console's test-user
# list is the primary gate).
ALLOWED_EMAILS=you@gmail.com,colleague@gmail.com

# Comma-separated Gmail addresses with admin privileges (budget settings, etc.).
# ONLY changeable by editing this file on this machine — never via the web UI or API.
# Removing an email here revokes admin on their next login.
ADMIN_EMAILS=you@gmail.com

# ── Optional ───────────────────────────────────────────────────────────────────

# Public URL of the app (used for OAuth redirect URI). Auto-detected if unset.
APP_URL=https://sentry.harieshwar.dev

# Telegram bot credentials (for digest notifications)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_ID=your-telegram-user-id
TELEGRAM_SUPERGROUP_ID=-100your-group-id
