{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@prisma/openclaw-client": ["./node_modules/@prisma/openclaw-client"],
      "@prisma/scout-client": ["./node_modules/@prisma/scout-client"]
    }
  },
  "include": ["scripts/**/*", "prisma/seed.ts"],
  "exclude": ["node_modules", "dist"]
}
